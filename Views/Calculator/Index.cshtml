<!-- ================= HERO ================= -->

<section class="hero">

    <div class="container text-center">

        <span class="badge bg-success px-3 py-2 mb-4">
            Science-Based Nutrition
        </span>

        <h1 class="display-3 fw-bold mb-4">

            Fuel Your
            <span class="text-success">
                Performance
            </span>

        </h1>

        <p class="lead hero-text">

            Calculate your maintenance calories,
            target calories, protein, carbs and fats
            using proven nutrition formulas.

        </p>

        <a href="#calculator"
           class="btn btn-success btn-lg px-5 mt-4">

            Start Calculating

        </a>

    </div>

</section>

<!-- ================= CALCULATOR ================= -->

<section id="calculator" class="py-5">

    <div class="container">

        <div class="calculator-card">

            <h2 class="text-center mb-4">
                Personal Information
            </h2>

            <form id="macroForm">

                <div class="row g-4">

                    <!-- Weight -->

                    <div class="col-md-6">

                        <label class="form-label">
                            Weight
                        </label>

                        <div class="input-group">

                            <input id="weight"
                                   type="number"
                                   class="form-control custom-input"
                                   placeholder="85">

                            <select id="weightUnit"
                                    class="form-select custom-input"
                                    style="max-width:110px;">

                                <option value="kg">
                                    kg
                                </option>

                                <option value="lbs">
                                    lbs
                                </option>

                            </select>

                        </div>

                    </div>

                    <!-- Height -->

                    <div class="col-md-6">

                        <label class="form-label">
                            Height (cm)
                        </label>

                        <input id="height"
                               type="number"
                               class="form-control custom-input"
                               placeholder="180">

                    </div>

                    <!-- Age -->

                    <div class="col-md-6">

                        <label class="form-label">
                            Age
                        </label>

                        <input id="age"
                               type="number"
                               class="form-control custom-input"
                               placeholder="27">

                    </div>

                    <!-- Gender -->

                    <div class="col-md-6">

                        <label class="form-label">
                            Gender
                        </label>

                        <select id="gender"
                                class="form-select custom-input">

                            <option value="Male">
                                Male
                            </option>

                            <option value="Female">
                                Female
                            </option>

                        </select>

                    </div>

                    <!-- Activity -->

                    <div class="col-md-6">

                        <label class="form-label">
                            Activity Level
                        </label>

                        <select id="activityLevel"
                                class="form-select custom-input">

                            <option value="Sedentary">
                                Sedentary
                            </option>

                            <option value="LightlyActive">
                                Lightly Active
                            </option>

                            <option value="ModeratelyActive" selected>
                                Moderately Active
                            </option>

                            <option value="VeryActive">
                                Very Active
                            </option>

                            <option value="ExtraActive">
                                Extra Active
                            </option>

                        </select>

                    </div>

                    <!-- Goal -->

                    <div class="col-md-6">

                        <label class="form-label">
                            Goal
                        </label>

                        <select id="goal"
                                class="form-select custom-input">

                            <option value="Maintain">
                                Maintain
                            </option>

                            <option value="Cut">
                                Cut
                            </option>

                            <option value="Bulk">
                                Bulk
                            </option>

                            <option value="Recomp">
                                Recomp
                            </option>

                        </select>

                    </div>

                    <!-- Protein Preference -->

                    <div class="col-md-12">

                        <label class="form-label">
                            Protein Preference
                        </label>

                        <select id="proteinPreference"
                                class="form-select custom-input">

                            <option value="Standard">
                                Standard
                            </option>

                            <option value="High">
                                High
                            </option>

                        </select>

                    </div>

                    <!-- Button -->
<div id="validationMessage"
     class="alert alert-danger d-none mb-3">
</div>
                    <div class="col-12 mt-4">

    <div id="validationMessage"
         class="alert alert-danger d-none mb-3">
    </div>

   <button
    id="calculateBtn"
    type="button"
    class="btn btn-success btn-lg w-100">

    <span id="buttonText">

        Calculate Macros

    </span>

    <span
        id="buttonSpinner"
        class="spinner-border spinner-border-sm ms-2 d-none">

    </span>

</button>

</div>

                </div>

            </form>

        </div>

    </div>

</section>

<!-- ================= RESULTS ================= -->

<section id="results" class="py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="fw-bold">Your Nutrition Plan</h2>

            <p class="text-secondary">
                Your calculated calories and macros will appear here.
            </p>

        </div>

        <div class="row g-4">

            <!-- Target Calories -->
            <div class="col-lg-4 col-md-6">
                <div class="result-card">
                    <div class="result-icon">🔥</div>
                    <h6>Target Calories</h6>
                    <h2 id="targetCalories">--</h2>
                    <small>kcal/day</small>
                </div>
            </div>

            <!-- Maintenance -->
            <div class="col-lg-4 col-md-6">
                <div class="result-card">
                    <div class="result-icon">⚡</div>
                    <h6>Maintenance</h6>
                    <h2 id="maintenanceCalories">--</h2>
                    <small>kcal/day</small>
                </div>
            </div>

            <!-- BMR -->
            <div class="col-lg-4 col-md-6">
                <div class="result-card">
                    <div class="result-icon">💪</div>
                    <h6>BMR</h6>
                    <h2 id="bmr">--</h2>
                    <small>Calories Burned at Rest</small>
                </div>
            </div>

            <!-- Protein -->
            <div class="col-lg-4 col-md-6">
                <div class="result-card">
                    <div class="result-icon">🥩</div>
                    <h6>Protein</h6>
                    <h2 id="protein">--</h2>
                    <small>grams</small>
                </div>
            </div>

            <!-- Carbs -->
            <div class="col-lg-4 col-md-6">
                <div class="result-card">
                    <div class="result-icon">🍚</div>
                    <h6>Carbohydrates</h6>
                    <h2 id="carbs">--</h2>
                    <small>grams</small>
                </div>
            </div>

            <!-- Fat -->
            <div class="col-lg-4 col-md-6">
                <div class="result-card">
                    <div class="result-icon">🥑</div>
                    <h6>Fat</h6>
                    <h2 id="fat">--</h2>
                    <small>grams</small>
                </div>
            </div>

        </div>

    </div>

</section>

<!-- ================= MACRO BREAKDOWN ================= -->

<section id="macroBreakdown" class="py-5">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <div class="chart-card">

                    <h3 class="mb-4">
                        Macro Distribution
                    </h3>

                    <canvas id="macroChart"></canvas>

                </div>

            </div>

            <div class="col-lg-6">

                <div class="chart-card">

                    <h3 class="mb-4">
                        Calories From Macros
                    </h3>

                    <div class="macro-progress">

                        <span>🥩 Protein</span>

                        <div class="progress">

                            <div id="proteinBar"
                                 class="progress-bar bg-danger"
                                 style="width:0%">
                            </div>

                        </div>

                    </div>

                    <div class="macro-progress">

                        <span>🍚 Carbohydrates</span>

                        <div class="progress">

                            <div id="carbBar"
                                 class="progress-bar bg-warning"
                                 style="width:0%">
                            </div>

                        </div>

                    </div>

                    <div class="macro-progress">

                        <span>🥑 Fat</span>

                        <div class="progress">

                            <div id="fatBar"
                                 class="progress-bar bg-success"
                                 style="width:0%">
                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

